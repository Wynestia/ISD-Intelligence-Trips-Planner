generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int           @id @default(autoincrement())
  firstName    String
  lastName     String
  email        String        @unique
  password     String
  phoneNumber  String
  birthday     DateTime
  gender       String
  chatSessions ChatSession[]
}

model ChatSession {
  chat_id   Int           @id @default(autoincrement())
  user_id   Int
  title     String
  create_at DateTime      @default(now())
  user      User          @relation(fields: [user_id], references: [id])
  messages  ChatMessage[]
}

model ChatMessage {
  message_id  Int         @id @default(autoincrement())
  session_id  Int
  role        String
  content     String
  token_count Int         @default(0)
  create_at   DateTime    @default(now())
  session     ChatSession @relation(fields: [session_id], references: [chat_id])
}
